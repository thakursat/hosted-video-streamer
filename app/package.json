{
  "name": "streamvault",
  "version": "2.0.0",
  "description": "Self-hosted, auth-gated video streaming server",
  "scripts": {
    "dev": "concurrently \"tsx watch src/index.ts\" \"npm run dev --prefix client\"",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "npm run build --prefix client",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/index.js",
    "set-password": "tsx src/cli/set-password.ts",
    "gen-secrets": "tsx src/cli/gen-secrets.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
