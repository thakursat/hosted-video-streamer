# App runtime — never commit these
app/node_modules/
app/client/node_modules/
app/dist/
app/client/dist/
app/config.json
app/secrets.json
app/meta-cache.json
app/download-queue.json
app/*.mp4
app/server.log
app/cookies.txt
app/yt-dlp
app/media/*
!app/media/.gitkeep
app/thumbnails/*.jpg
app/thumbnails/*.vtt
!app/thumbnails/.gitkeep

app/client/*.tsbuildinfo
app/*.tsbuildinfo

# NOTE: streamvault-app.tar.gz IS committed on purpose (the installer pulls it).
